{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "barcode": { "type": "string", "description": "Product barcode" },
        "category": { "type": "string", "description": "Product category" },
        "stock": { "type": "number", "description": "Available stock" },
        "imageUrl": { "type": "string", "description": "Product image URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "barcode", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed transaction",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["items", "total", "timestamp", "userId"]
    },
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales history"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}

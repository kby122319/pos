rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name (string), price (number), barcode (string), category (string), stock (number), imageUrl (string), createdAt (timestamp)
    //
    // Collection: sales
    // Fields: items (list of maps), total (number), timestamp (timestamp), userId (string)
    //
    // Collection: users
    // Fields: email (string), role (string: 'admin' | 'staff'), displayName (string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kurtvilleyambagon@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff']);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'barcode', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.barcode is string && data.barcode.size() > 0 && data.barcode.size() < 50 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'total', 'timestamp', 'userId']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.timestamp is timestamp &&
             data.userId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'staff'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'staff' || isAdmin());
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
